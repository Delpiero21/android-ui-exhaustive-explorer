<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- run 종료 후 PC server (127.0.0.1:8000 via adb reverse) 로 자동 업로드 -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Foreground service: Android 12+ 백그라운드 액션 launch 제한 우회를 위해 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!--
      Android 11+ Package Visibility:
        getLaunchIntentForPackage() 가 다른 앱을 "보려면" 명시적 선언 필요.
        본 도구는 모든 launcher 앱을 자율 탐색 대상으로 삼으므로 LAUNCHER 카테고리 전체 허용.
        또한 QUERY_ALL_PACKAGES — accessibility 도구 본질상 정당 (사내 배포, Play Store 비대상).
    -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
    </queries>

    <!-- Loopback-only egress; cleartext to 127.0.0.1 / localhost is the only allowed traffic. -->
    <application
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:supportsRtl="true"
        android:theme="@style/Theme.AndroidUIExhaustiveExplorer"
        tools:targetApi="35">

        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.AndroidUIExhaustiveExplorer">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- AccessibilityService — foreground service 로 격상 (autonomous 모드 시) -->
        <service
            android:name=".service.ExplorerAccessibilityService"
            android:exported="true"
            android:foregroundServiceType="specialUse"
            android:label="@string/accessibility_service_label"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="ui_exploration" />
        </service>
    </application>
</manifest>
